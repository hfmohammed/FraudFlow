# Default values for docker-compose.yml.
# Copy this file to .env.local and override values there for local experiments.
# .env is committed (no secrets); .env.local is gitignored.

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=fraudflow

KAFKA_TOPIC=transactions
EVENTS_PER_MINUTE=1000
FRAUD_RATE=0.015
NUM_CARDS=500
NUM_MERCHANTS=200

DELTA_BASE_PATH=dbfs:/fraudflow