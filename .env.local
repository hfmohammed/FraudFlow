# Default values for docker-compose.yml, committed to the repo.
# Copy this file to .env and override values there for local experiments.
# .env.local is committed (no secrets); .env is gitignored.

# grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=fraudflow

# kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9094
KAFKA_TOPIC=transactions
EVENTS_PER_MINUTE=1000
FRAUD_RATE=0.015
NUM_CARDS=500
NUM_MERCHANTS=200
METRICS_PORT=8000

# delta
DELTA_BASE_PATH=dbfs:/fraudflow